# =============================================================
# GENESIS — OpenRouter API Keys Template
# =============================================================
# 1. cp .env.example .env
# 2. Fill in your real keys in .env (NEVER commit .env!)
# 3. The pool manager reads ANY env var matching:
#    OPENROUTER_API_KEY        (single key, default)
#    OPENROUTER_API_KEY_<NAME> (additional keys with custom labels)
#
# Example: 11 free-tier accounts, each labeled by account name.
# The pool manager will rotate automatically when one hits rate limits.

# Primary (used if only one)
OPENROUTER_API_KEY=

# Multiple accounts (one per line; any label after the prefix works)
OPENROUTER_API_KEY_AHMED=
OPENROUTER_API_KEY_FARESRAFATFARES=
OPENROUTER_API_KEY_FARESRAFAT433=
OPENROUTER_API_KEY_FARESRAFAT434=
OPENROUTER_API_KEY_FARESRAFAT435=
OPENROUTER_API_KEY_FARESRAFAT436=
OPENROUTER_API_KEY_FARESRAFAT437=
OPENROUTER_API_KEY_FARESRAFAT818=
OPENROUTER_API_KEY_FARMFARES1=
OPENROUTER_API_KEY_FARMFARES2=
OPENROUTER_API_KEY_FARMFARES3=

# Optional: override base URL (default is OpenRouter)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# =============================================================
# SECURITY NOTES
# =============================================================
# - .env is in .gitignore (verify before any commit!)
# - Run `git diff --cached | grep "sk-or-v1-"` before pushing
# - If a key ever appears in a commit, REVOKE it immediately at:
#   https://openrouter.ai/settings/keys
# - Free tier keys still expose your IP and usage patterns
