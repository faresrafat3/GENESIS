# =============================================================
# GENESIS — Multi-Provider LLM API Keys Template
# =============================================================
# 1. cp .env.example .env
# 2. Fill in keys for whichever providers you want to use
# 3. The pool managers will auto-detect which are configured
#
# YOU DON'T NEED ALL OF THEM — even 1-2 providers gives big gains
# over OpenRouter alone. Recommended priority: Google Gemini, Groq,
# Cerebras, then OpenRouter as fallback.

# ─── 🥇 Google Gemini (1500 req/day Flash, 50 RPD Pro, no card) ───
# Setup: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── 🥈 Groq (1000 req/day per model, ~315 tok/s, no card) ───
# Setup: https://console.groq.com/keys
GROQ_API_KEY=

# ─── 🥉 Cerebras (1M tokens/day, 30 RPM, no card) ───
# Setup: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# ─── NVIDIA NIM (Nemotron direct, phone verify may be needed) ───
# Setup: https://build.nvidia.com
NVIDIA_API_KEY=

# ─── 🔥 GitHub Models (GPT-5, Claude Sonnet, Grok 3 - all FREE!) ───
# Setup: https://github.com/settings/tokens (need 'models:read' scope)
GITHUB_TOKEN=

# ─── DeepSeek (cheap reasoning, generous free tier) ───
# Setup: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ─── Mistral (EU data, free experiment tier) ───
# Setup: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ─── Cloudflare Workers AI (10k neurons/day, edge inference) ───
# Setup: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# =============================================================
# OpenRouter — Multi-key Support (Current Setup)
# =============================================================
# Pool will pick up ALL env vars matching OPENROUTER_API_KEY_<NAME>
# Each free account: 50 req/day per model

# Primary (used if only one)
OPENROUTER_API_KEY=

# Multiple accounts (any label after the prefix works)
OPENROUTER_API_KEY_AHMED=
OPENROUTER_API_KEY_FARESRAFATFARES=
OPENROUTER_API_KEY_FARESRAFAT433=
OPENROUTER_API_KEY_FARESRAFAT434=
OPENROUTER_API_KEY_FARESRAFAT435=
OPENROUTER_API_KEY_FARESRAFAT436=
OPENROUTER_API_KEY_FARESRAFAT437=
OPENROUTER_API_KEY_FARESRAFAT818=
OPENROUTER_API_KEY_FARMFARES1=
OPENROUTER_API_KEY_FARMFARES2=
OPENROUTER_API_KEY_FARMFARES3=

# =============================================================
# Optional base URL overrides (rarely needed)
# =============================================================
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# =============================================================
# SECURITY NOTES
# =============================================================
# - .env is in .gitignore (verify before any commit!)
# - Run `git diff --cached | grep -E "sk-|gsk_|csk-|github_pat_|nvapi-"` before pushing
# - If a key ever appears in a commit, REVOKE it immediately
# - Each provider has separate dashboard for revocation:
#   * Google Gemini: https://aistudio.google.com/app/apikey
#   * Groq: https://console.groq.com/keys
#   * Cerebras: https://cloud.cerebras.ai
#   * NVIDIA: https://build.nvidia.com (account settings)
#   * GitHub: https://github.com/settings/tokens
#   * OpenRouter: https://openrouter.ai/settings/keys

# =============================================================
# TIER MATRIX (cheat sheet)
# =============================================================
# Total estimated free capacity if ALL providers are configured:
#   Google Gemini:  ~1,550 req/day (Flash 1500 + Pro 50)
#   Groq:           ~3,000 req/day (3 models × 1000)
#   Cerebras:       ~500-1000 req/day (1M tokens / avg 2K tokens)
#   NVIDIA NIM:     ~500 req/day (per-account, varies)
#   GitHub Models:  varies by Copilot tier
#   OpenRouter:     ~2,750 req/day (11 keys × 5 models × 50)
#   ─────────────────────────────────────────────────────────
#   TOTAL:          ~8,000+ req/day on frontier models!
#
# Compare to OpenRouter alone: 2,750 req/day = ~3× more capacity
