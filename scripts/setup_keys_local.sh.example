#!/bin/bash
# =============================================================
# GENESIS — Local API Keys Setup (TEMPLATE — DO NOT COMMIT FILLED VERSION)
# =============================================================
# Usage:
#   cp scripts/setup_keys_local.sh.example scripts/setup_keys_local.sh
#   chmod 600 scripts/setup_keys_local.sh   # restrict permissions
#   # Edit scripts/setup_keys_local.sh, paste your real keys
#   bash scripts/setup_keys_local.sh        # writes .env
#
# scripts/setup_keys_local.sh is in .gitignore — it will NEVER be pushed.
# .env is also in .gitignore.

set -e

cd "$(dirname "$0")/.."

if [[ -f .env ]]; then
    read -p ".env already exists. Overwrite? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi
    cp .env .env.backup.$(date +%s)
    echo "Backed up old .env"
fi

# Replace these placeholders with your actual keys
cat > .env <<EOF
# Generated by setup_keys_local.sh on $(date)
# DO NOT COMMIT THIS FILE

OPENROUTER_API_KEY_AHMED=sk-or-v1-PASTE-KEY-1-HERE
OPENROUTER_API_KEY_FARESRAFATFARES=sk-or-v1-PASTE-KEY-2-HERE
OPENROUTER_API_KEY_FARESRAFAT433=sk-or-v1-PASTE-KEY-3-HERE
OPENROUTER_API_KEY_FARESRAFAT434=sk-or-v1-PASTE-KEY-4-HERE
OPENROUTER_API_KEY_FARESRAFAT435=sk-or-v1-PASTE-KEY-5-HERE
OPENROUTER_API_KEY_FARESRAFAT436=sk-or-v1-PASTE-KEY-6-HERE
OPENROUTER_API_KEY_FARESRAFAT437=sk-or-v1-PASTE-KEY-7-HERE
OPENROUTER_API_KEY_FARESRAFAT818=sk-or-v1-PASTE-KEY-8-HERE
OPENROUTER_API_KEY_FARMFARES1=sk-or-v1-PASTE-KEY-9-HERE
OPENROUTER_API_KEY_FARMFARES2=sk-or-v1-PASTE-KEY-10-HERE
OPENROUTER_API_KEY_FARMFARES3=sk-or-v1-PASTE-KEY-11-HERE

OPENAI_BASE_URL=https://openrouter.ai/api/v1
EOF

chmod 600 .env
echo "✓ Wrote .env with restricted permissions (600)"
echo "Now run:"
echo "  python3 tools/api_key_pool.py --test_call"
echo "to verify keys work."
